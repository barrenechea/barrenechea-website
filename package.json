{
  "name": "barrenechea-website",
  "version": "1.0.0",
  "author": "Sebastian Barrenechea (https://github.com/barrenechea)",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint . && astro check",
    "format": "prettier --log-level warn --write .",
    "prepare": "husky",
    "i18n:generate": "npm run format && node --experimental-strip-types --no-warnings tools/translateContent.ts en && npm run format && node --experimental-strip-types --no-warnings tools/translateContent.ts && npm run format"
  },
  "lint-staged": {
    "*": "prettier --write",
    "*.{js,cjs,mjs,ts,astro}": [
      "eslint --fix",
      "astro check"
    ]
  },
  "dependencies": {
    "@astro-community/astro-embed-youtube": "^0.5.10",
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/partytown": "^2.1.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@fontsource/work-sans": "^5.2.8",
    "@iconify-icons/circle-flags": "^1.2.41",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.5",
    "astro-og-canvas": "^0.11.0",
    "astro-robots-txt": "^1.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "github-fork-ribbon-css": "^0.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "openai": "^6.34.0",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2"
  },
  "packageManager": "npm@11.12.1",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "typescript-eslint": "^8.58.1"
  },
  "overrides": {
    "eslint": "^10.2.0",
    "@eslint/js": "^10.0.1",
    "vite": "^8.0.3"
  }
}
